# 复制本文件为 .env 并按需修改，或直接运行 `gch init` 交互式生成。
# 通过切换 base_url + model 即可在不同 LLM 提供商之间切换（均兼容 OpenAI 协议）。
#
# 【安全约定】API Key 不写入 .env，改用环境变量注入，避免随项目泄露：
#   export LLM_API_KEY="你的真实密钥"
# 环境变量优先级高于 .env，因此 .env 中不出现密钥也能正常工作。

# LLM 接口地址（示例为 DeepSeek，可换成通义/Kimi/Ollama/OpenAI）
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
LLM_MODEL=deepseek-chat

# 生成温度（0~1，越低越稳定）
LLM_TEMPERATURE=0.2

# 单次请求最大 token
LLM_MAX_TOKENS=512

# 失败重试次数
LLM_MAX_RETRIES=3

# diff 截断阈值（字符数）
DIFF_MAX_CHARS=12000

# Conventional Commits 首行长度上限
SUBJECT_MAX_LENGTH=72

# 自定义 prompt 模板路径（可选）
# PROMPT_TEMPLATE_PATH=templates/prompt_1.j2

# 自定义周报 prompt 模板路径（可选）
# REPORT_PROMPT_TEMPLATE_PATH=templates/report.j2

# ---- 常见提供商参考 ----
# DeepSeek : LLM_BASE_URL=https://api.deepseek.com/v1            LLM_MODEL=deepseek-chat
# 通义千问 : LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL=qwen-plus
# Kimi     : LLM_BASE_URL=https://api.moonshot.cn/v1            LLM_MODEL=moonshot-v1-8k
# Ollama   : LLM_BASE_URL=http://localhost:11434/v1            LLM_MODEL=qwen2.5
# OpenAI   : LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini

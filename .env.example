# 复制本文件为 .env 并填入真实值：cp .env.example .env
# 通过切换 base_url + model 即可在不同 LLM 提供商之间切换（均兼容 OpenAI 协议）

# LLM 接口地址（示例为 DeepSeek，可换成通义/Kimi/Ollama/OpenAI）
LLM_BASE_URL=https://api.deepseek.com/v1

# API Key（DeepSeek/OpenAI 等需要；本地 Ollama 可随意填）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# 模型名称
LLM_MODEL=deepseek-chat

# 生成温度（0~1，越低越稳定）
LLM_TEMPERATURE=0.2

# 单次请求最大 token
LLM_MAX_TOKENS=512

# ---- 常见提供商参考 ----
# DeepSeek : LLM_BASE_URL=https://api.deepseek.com/v1            LLM_MODEL=deepseek-chat
# 通义千问 : LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL=qwen-plus
# Kimi     : LLM_BASE_URL=https://api.moonshot.cn/v1            LLM_MODEL=moonshot-v1-8k
# Ollama   : LLM_BASE_URL=http://localhost:11434/v1            LLM_MODEL=qwen2.5
# OpenAI   : LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini
